site_name: 诺丁汉大学数学系升学参考平台
site_url: https://phoenizard.github.io/GraduateForm/
site_author: 诺丁汉数学系飞跃手册
copyright: 'Copyright &copy; {{ current_year }} 诺丁汉数学系飞跃手册. All rights reserved.'

repo_name: Phoenizard/GraduateForm
repo_url: https://github.com/Phoenizard/GraduateForm/

theme:
  name: material
  custom_dir: overrides
  palette:
    - media: "(prefers-color-scheme: light)"
      scheme: default
      primary: custom
      accent: custom
      toggle:
        icon: material/toggle-switch
        name: Switch to dark mode
    - media: "(prefers-color-scheme: dark)"
      scheme: slate
      primary: custom
      accent: custom
      toggle:
        icon: material/toggle-switch-off-outline
        name: Switch to light mode
  features:
    - announce.dismiss
    - search.highlight
    - search.share
    - toc.follow
    - navigation.footer
    - navigation.indexes
    - navigation.instant
    - navigation.instant.prefetch
    - navigation.path
    - navigation.sections
    - navigation.tracking
    - navigation.tabs
    - navigation.top
  font:
    text: 'Fira Sans'
    code: 'Fira Mono'
  icon:
    repo: fontawesome/brands/github

extra_css:
- stylesheets/extra.css

plugins:
  - search:
      lang:
        - en
        - zh
      separator: '[\s\u200b\-,:!=\[\]()"`/@]+|\.(?!\d)|&[lg]t;|(?!\b)(?=[A-Z][a-z])'

markdown_extensions:
  # Python Markdown
  - abbr
  - admonition
  - attr_list
  - def_list
  - footnotes
  - md_in_html
  - tables
  - toc:
      permalink: true
      toc_depth: 2
      slugify: !!python/object/apply:pymdownx.slugs.slugify
        kwds:
          case: lower
  # Python Markdown Extensions
  - pymdownx.arithmatex:
      generic: true
  - pymdownx.betterem:
      smart_enable: all
  - pymdownx.caret
  - pymdownx.details
  - pymdownx.emoji:
      emoji_index: !!python/name:material.extensions.emoji.twemoji
      emoji_generator: !!python/name:material.extensions.emoji.to_svg
  - pymdownx.highlight
  - pymdownx.inlinehilite
  - pymdownx.keys
  - pymdownx.mark
  - pymdownx.smartsymbols
  - pymdownx.superfences
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.tasklist:
      custom_checkbox: true
  - pymdownx.tilde

nav:
  - Home:
    - index.md
  - Prefaces:
    - 前言 2026: prefaces/preface-2026.md
  - Articles:
{%- for a in articles %}
    - {{ a.title }}: articles/{{ a.slug }}.md
{%- endfor %}
  - Applicants:
    - applicants/index.md
    - Term:
{%- for term, students in students_by_term.items() %}
      - {{ term }}:
{%- for student in students %}
        - {{ student.name }} <small>/ {{ student.program_choice[0].display_value }}</small>: applicants/{{ student.s_id }}.md
{%- endfor %}
{%- endfor %}
  - Programs:
    - programs/index.md
{%- for region, universities in universities_by_region.items() %}
    - {{ region }}:
{%- for university in universities %}
      - {{ university.abbrv }}:
{%- for program in university.programs %}
{%- set program = programs[program.row_id] %}
        - {{ program.abbrv }}: programs/{{ program.p_id }}.md
{%- endfor %}
{%- endfor %}
{%- endfor %}
